# Copy to .env (Prisma CLI) and .env.local (Next.js dev).
# Never commit real credentials.
# Optional: .env.ingest for DSS cron (writer DATABASE_URL) — gitignored

# --- Vercel / CI preview ---
# MARKET_DATA_SOURCE=static
# (no DATABASE_URL; uses data/market-quotes-snapshot.json)

# --- DSS production app (readonly pooler) ---
# MARKET_DATA_SOURCE=db
# DATABASE_URL="postgresql://stocklens_readonly:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"

# --- Local default (pick one mode in .env.local) ---
MARKET_DATA_SOURCE=static

# Supabase pooler — app + ingest (copy full host from dashboard, e.g. aws-1-ap-southeast-1)
# Wrong: ap-southeast-1.pooler.supabase.com (region slug only → ENOTFOUND)
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — Prisma Migrate only (port 5432, Session or db.*.supabase.co)
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"
