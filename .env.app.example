# Next.js on DSS (PM2 / systemd / Docker). Read-only DB user — not for cron.
#
# Do not copy writer credentials from .env.ingest.

MARKET_DATA_SOURCE=db
DATABASE_URL="postgresql://READONLY_USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Optional tunnel (same as .env.ingest if VM uses SSH tunnel):
# DATABASE_URL="postgresql://READONLY_USER:PASS@127.0.0.1:5433/postgres"
