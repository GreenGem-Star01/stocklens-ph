module.exports = {
  apps: [
    {
      name: "stocklens",
      cwd: "/var/www/stocklens-ph",
      script: "npm",
      args: "start",
      env: {
        NODE_ENV: "production",
        MARKET_DATA_SOURCE: "db",
        // Use readonly pooler URL — not .env.ingest
        DATABASE_URL: "postgresql://READONLY:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true",
      },
    },
  ],
};
