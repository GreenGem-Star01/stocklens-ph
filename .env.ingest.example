# Copy to .env.ingest on the DSS VM (gitignored). Writer credentials only — never use in Next.js.
#
# cp .env.ingest.example .env.ingest

# Supabase pooler (port 6543, pgbouncer=true) — stocklens_ingest user recommended
DATABASE_URL="postgresql://INGEST_USER:PASSWORD@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Optional: if cron cannot find npm (uncomment and set full paths from `which node` / `which npm`)
# NODE_BIN=/usr/local/bin/node
# NPM_BIN=/usr/local/bin/npm

# Optional: SSH tunnel — use 127.0.0.1:LOCAL_PORT instead of Supabase host
# DATABASE_URL="postgresql://USER:PASS@127.0.0.1:5433/postgres"
